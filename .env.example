COHERE_API_KEY=sdfgdh
OPENAI_API_KEY=adfsgf
OPENAI_CHAT_MODEL="gpt-5.4"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# ── Database connections ──────────────────────────────────────────────────────
# The hostnames below (pgvector_db, agentic_db) are the SERVICE NAMES from
# docker-compose.yml. Inside Docker Compose the app reaches each database over the
# internal network by that name (NOT via localhost). Leave these as-is when you run
# the stack with `docker compose up` — this is the recommended way to run the demo.
#
# Running the app directly on your host instead (no Docker)? Use the published host
# ports from docker-compose.yml:
#   PG_CONNECTION_STRING=postgresql+psycopg://arun:postgres@localhost:5440/reranking_rag_db
#   AGENTIC_RAG_DB_URL=postgresql+psycopg://rag_readonly:rag_readonly_pass@localhost:5441/agentic_rag_db

# PGVector store (document embeddings). User/password/db match the pgvector_db service.
PG_CONNECTION_STRING=postgresql+psycopg://arun:postgres@pgvector_db:5432/reranking_rag_db

# Agentic RAG e-commerce database for the NL2SQL tool.
# rag_readonly is a SELECT-only role created by sql/seed.sql.
AGENTIC_RAG_DB_URL=postgresql+psycopg://rag_readonly:rag_readonly_pass@agentic_db:5432/agentic_rag_db

# Guardrails.io
# Hub token (JWT, expires ~90 days) from https://hub.guardrailsai.com/keys.
# NOTE: this key does NOT install the validators — you must still run
#   guardrails hub install hub://guardrails/detect_pii        [--no-install-local-models]
#   guardrails hub install hub://guardrails/toxic_language    [--no-install-local-models]
#   guardrails hub install hub://tryolabs/restricttotopic     [--no-install-local-models]
# (RestrictToTopic lives under the `tryolabs` namespace, not `guardrails`.)
GUARDRAILS_API_KEY=fsgdfgdgfhfd
# Run validator inference on Guardrails' hosted endpoint instead of downloading
# models locally (skips the ~2 GB download). Requires GUARDRAILS_API_KEY above.
# IMPORTANT: this flag is only read when the app first writes ~/.guardrailsrc. If
# that file already exists it is NOT overwritten, so this value is ignored — set
# `use_remote_inferencing` in ~/.guardrailsrc directly (or re-run `guardrails
# configure`). It also does not remove the install step above.
GUARDRAILS_USE_REMOTE_INFERENCING=false

TAVILY_API_KEY=tvly-abcd