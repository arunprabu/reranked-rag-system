COHERE_API_KEY=sdfgdh
OPENAI_API_KEY=adfsgf
OPENAI_CHAT_MODEL="gpt-5.4"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# PGVector store connection (used by LangChain PGVector for document embeddings)
PG_CONNECTION_STRING=postgresql+psycopg://your_user:your_password@localhost:5432/your_pgvector_db

# Agentic RAG e-commerce database connection (used by the NL2SQL tool)
# Credentials match sql/seed.sql — rag_readonly is a SELECT-only role
AGENTIC_RAG_DB_URL=postgresql+psycopg://rag_readonly:rag_readonly_pass@localhost:5432/agentic_rag_db

# Guardrails.io
# Hub token (JWT, expires ~90 days) from https://hub.guardrailsai.com/keys.
# NOTE: this key does NOT install the validators — you must still run
#   guardrails hub install hub://guardrails/detect_pii        [--no-install-local-models]
#   guardrails hub install hub://guardrails/toxic_language    [--no-install-local-models]
#   guardrails hub install hub://tryolabs/restricttotopic     [--no-install-local-models]
# (RestrictToTopic lives under the `tryolabs` namespace, not `guardrails`.)
GUARDRAILS_API_KEY=fsgdfgdgfhfd
# Run validator inference on Guardrails' hosted endpoint instead of downloading
# models locally (skips the ~2 GB download). Requires GUARDRAILS_API_KEY above.
# IMPORTANT: this flag is only read when the app first writes ~/.guardrailsrc. If
# that file already exists it is NOT overwritten, so this value is ignored — set
# `use_remote_inferencing` in ~/.guardrailsrc directly (or re-run `guardrails
# configure`). It also does not remove the install step above.
GUARDRAILS_USE_REMOTE_INFERENCING=false